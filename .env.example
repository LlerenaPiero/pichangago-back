# =============================================
# 🗄️  BASE DE DATOS — AZURE SQL
# =============================================
DB_SERVER=your-server.database.windows.net
DB_NAME=PichangaGO
DB_USER=your_admin
DB_PASSWORD=your_password
DB_ENCRYPT=true
DB_TRUST_CERT=false

# =============================================
# 🔐 SEGURIDAD — JWT
# =============================================
JWT_SECRET=your-random-secret-key-min-32-chars
REFRESH_TOKEN_SECRET=your-refresh-secret-key-min-32-chars

# =============================================
# 🌐 FRONTEND — ORÍGENES CORS
# =============================================
# Puedes usar FRONTEND_URL (un solo origen) o CORS_ORIGINS (varios separados por coma)
# Ejemplo CORS_ORIGINS: https://pichangago-front.vercel.app,http://localhost:5173
FRONTEND_URL=https://pichangago-front.vercel.app
# CORS_ORIGINS=https://pichangago-front.vercel.app,http://localhost:5173

# =============================================
# 🔑 GOOGLE OAUTH — LOGIN CON GOOGLE
# =============================================
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-tu-secreto

# =============================================
# 📧 EMAIL — CONTRASEÑA DE APLICACIÓN (GMAIL)
# =============================================
# Requiere: 2FA activado en el Gmail y generar App Password en:
# https://myaccount.google.com/apppasswords
EMAIL_USER=tu-correo@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# =============================================
# 🔗 BACKEND — URL PÚBLICA
# =============================================
# Necesaria para que toProxyUrl genere URLs absolutas (ej: https://pichangago-back.onrender.com)
# Sin esto, las URLs de imágenes serán relativas y fallarán desde el frontend con OpaqueResponseBlocking
API_URL=https://pichangago-back.onrender.com

# =============================================
# ☁️  AZURE BLOB STORAGE — IMÁGENES
# =============================================
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=your-key;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=canchas

# =============================================
# 🧪 RATE LIMIT — PRUEBAS DE CARGA
# =============================================
# Por defecto: 100 req/min. Para pruebas con k6 aumentarlo (ej: 2000)
# RATE_LIMIT_MAX=2000
#
# Límite de intentos de login (por defecto: 5 cada 15 min).
# Para pruebas con k6: AUTH_RATE_LIMIT_MAX=2000 y AUTH_RATE_LIMIT_WINDOW_MS=60000
# AUTH_RATE_LIMIT_MAX=2000
# AUTH_RATE_LIMIT_WINDOW_MS=60000
