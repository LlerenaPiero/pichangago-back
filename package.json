    "google-auth-library": "^10.9.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "mssql": "^12.5.4",
    "multer": "^1.4.5-lts.2",
    "nodemailer": "^8.0.7",
